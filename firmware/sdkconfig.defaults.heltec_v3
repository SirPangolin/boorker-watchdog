# Heltec WiFi LoRa 32 V3 (V3.2)
# 8MB Flash, no PSRAM, SX1262 LoRa, SSD1306 OLED
# GPIO 8-14 reserved for LoRa, 17/18/21 for OLED

# No PSRAM (512KB SRAM only, ~379KB free heap)
# CONFIG_SPIRAM is not set

# Sensors (same GPIOs as DevKitC — no conflicts on Heltec V3)
CONFIG_DHT22_DEFAULT_GPIO=2
CONFIG_SW420_DEFAULT_GPIO=5

# Buzzer - GPIO6, Timer 0, Channel 4
CONFIG_BUZZER_DRIVER_GPIO=6
CONFIG_BUZZER_DRIVER_LEDC_TIMER=0
CONFIG_BUZZER_DRIVER_LEDC_CHANNEL=4

# Onboard LED - white GPIO on GPIO35
CONFIG_LED_DRIVER_ONBOARD_GPIO=y
CONFIG_LED_DRIVER_ONBOARD_GPIO_NUM=35

# External LED - RGB LEDC on R=4, G=7, B=3
# (GPIO 8,9 are LoRa SX1262 — cannot use DevKitC's R=9,B=8)
CONFIG_LED_DRIVER_EXTERNAL_ENABLED=y
CONFIG_LED_DRIVER_EXTERNAL_RGB_LEDC=y
CONFIG_LED_DRIVER_EXTERNAL_GPIO_R=4
CONFIG_LED_DRIVER_EXTERNAL_GPIO_G=7
CONFIG_LED_DRIVER_EXTERNAL_GPIO_B=3

# HTTPS - 2 connections (no PSRAM, each TLS conn ~40-50KB)
CONFIG_HTTP_SERVER_MAX_CONNECTIONS=2

# Buzzer volumes (50% for audible testing, default 2% is inaudible)
CONFIG_STATUS_BUZZER_VOLUME_CHIRP=50
CONFIG_STATUS_BUZZER_VOLUME_DOUBLE_BEEP=50
CONFIG_STATUS_BUZZER_VOLUME_TRIPLE_BEEP=50
CONFIG_STATUS_BUZZER_VOLUME_ALARM=50
CONFIG_STATUS_BUZZER_VOLUME_SOLID=50

# Vext power rail - GPIO36 controls 3.3V to external sensors
# Active LOW (P-channel MOSFET) — LOW = sensors powered
CONFIG_BOARD_VEXT_ENABLED=y
CONFIG_BOARD_VEXT_GPIO=36
