# ESP32-S3-DevKitC-1-N32R8V v1.1
# 32MB Flash, 8MB Octal PSRAM, WS2812 RGB LED

# PSRAM (8MB Octal)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# Sensors
CONFIG_DHT22_DEFAULT_GPIO=2
CONFIG_SW420_DEFAULT_GPIO=5

# Buzzer - GPIO6, Timer 0, Channel 4
CONFIG_BUZZER_DRIVER_GPIO=6
CONFIG_BUZZER_DRIVER_LEDC_TIMER=0
CONFIG_BUZZER_DRIVER_LEDC_CHANNEL=4

# Onboard LED - WS2812 on GPIO38 (DevKitC v1.1)
CONFIG_LED_DRIVER_ONBOARD_WS2812=y
CONFIG_LED_DRIVER_ONBOARD_GPIO_NUM=38

# External LED - RGB LEDC on R=9, G=7, B=8
# Physical LED pinout: R(9) - Common(GND) - G(7) - B(8)
CONFIG_LED_DRIVER_EXTERNAL_ENABLED=y
CONFIG_LED_DRIVER_EXTERNAL_RGB_LEDC=y
CONFIG_LED_DRIVER_EXTERNAL_GPIO_R=9
CONFIG_LED_DRIVER_EXTERNAL_GPIO_G=7
CONFIG_LED_DRIVER_EXTERNAL_GPIO_B=8

# HTTPS - 4 connections (has PSRAM, ~8.5MB heap)
CONFIG_HTTP_SERVER_MAX_CONNECTIONS=4

# No Vext on DevKitC — sensors powered from main 3V3
# CONFIG_BOARD_VEXT_ENABLED is not set
