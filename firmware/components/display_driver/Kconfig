menu "Display Driver"

    config DISPLAY_DRIVER_ENABLED
        bool "Enable OLED display"
        default n
        help
            Enable SSD1306 OLED display over I2C. Disable for boards without OLED.

    if DISPLAY_DRIVER_ENABLED

        config DISPLAY_DRIVER_I2C_PORT
            int "I2C port number"
            default 0
            range 0 1
            help
                I2C port (I2C_NUM_0 or I2C_NUM_1).
                Display claims this port. Future I2C sensors should use the other.

        config DISPLAY_DRIVER_I2C_SDA
            int "I2C SDA GPIO"
            default 17
            range 0 48
            help
                I2C data GPIO. Heltec V3: GPIO17 (internal to OLED, not on headers).

        config DISPLAY_DRIVER_I2C_SCL
            int "I2C SCL GPIO"
            default 18
            range 0 48
            help
                I2C clock GPIO. Heltec V3: GPIO18 (internal to OLED, not on headers).

        config DISPLAY_DRIVER_I2C_FREQ
            int "I2C frequency (Hz)"
            default 400000
            help
                I2C bus frequency. SSD1306 supports up to 400kHz.

        config DISPLAY_DRIVER_RST_GPIO
            int "Display reset GPIO"
            default 21
            range -1 48
            help
                GPIO for display hardware reset. Set -1 to disable.
                Heltec V3: GPIO21. Drive HIGH to enable, LOW to reset.

        config DISPLAY_DRIVER_I2C_ADDR
            hex "SSD1306 I2C address"
            default 0x3C
            help
                I2C slave address for SSD1306. Usually 0x3C or 0x3D.

        config DISPLAY_DRIVER_WIDTH
            int "Display width (pixels)"
            default 128
            help
                Horizontal resolution of the OLED panel.

        config DISPLAY_DRIVER_HEIGHT
            int "Display height (pixels)"
            default 64
            range 32 64
            help
                Vertical resolution. SSD1306 supports 128x64 or 128x32.

    endif # DISPLAY_DRIVER_ENABLED

endmenu
