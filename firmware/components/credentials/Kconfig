menu "Credentials"

    config CRED_WEB_PASS_LEN
        int "Web password length"
        default 12
        range 8 32
        help
            Length of auto-generated web password

    config CRED_AP_PASS_LEN
        int "AP password length"
        default 12
        range 8 32
        help
            Length of auto-generated AP password

    config CRED_NAME_PREFIX
        string "Device name prefix"
        default "boorker"
        help
            Prefix for device name (suffix is MAC-derived)

    config CRED_LOG_CREDENTIALS
        bool "Log credentials to serial on first boot"
        default y
        help
            Enable to print generated credentials to serial console.
            Disable for production builds.

endmenu
