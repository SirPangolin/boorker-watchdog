menu "Buzzer Driver"

    config BUZZER_DRIVER_GPIO
        int "Buzzer GPIO pin"
        default 6
        range 0 48
        help
            GPIO pin connected to buzzer signal (I/O pin).

    config BUZZER_DRIVER_LEDC_TIMER
        int "LEDC timer number"
        default 0
        range 0 3
        help
            LEDC timer to use (0-3). LED driver uses timer 1 for external
            RGB LEDC — use timer 0 to avoid conflicts.

    config BUZZER_DRIVER_LEDC_CHANNEL
        int "LEDC channel number"
        default 4
        range 0 7
        help
            LEDC channel to use (0-7). LED driver uses channels 1-3 for
            external RGB LEDC — use channel 4+ to avoid conflicts.

    config BUZZER_DRIVER_PWM_FREQ
        int "PWM frequency (Hz)"
        default 1000
        range 100 10000
        help
            PWM frequency for volume modulation. Does not affect buzzer tone
            (active buzzer has fixed internal frequency).

endmenu
